# ==============================================================
# Consultio Med - Production Environment
# Copy to .env.production and fill in the values
# ================================================= ==============================================================

# --- APPLICATION ---
NODE_ENV=production
PORT=5173
APP_URL=https://woomed.consultio.com.br
CORS_ORIGIN=https://woomed.consultio.com.br

# --- SECURITY (GENERATE UNIQUE VALUES!) ---
# Generate with: openssl rand -base64 32
JWT_SECRET=GENERATE_WITH_OPENSSL
# Generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=GENERATE_WITH_OPENSSL

# --- DATABASE ---
DATABASE_URL=postgresql://user:password@host:5432/consultio

# --- WHATSAPP ---
WHATSMEOW_API_URL=http://whatsmeow-bridge:8080
WHATSMEOW_WEBHOOK_SECRET=GENERATE_WITH_OPENSSL

# --- PLATFORM ---
PLATFORM_OWNER_EMAIL=admin@yourdomain.com
PLATFORM_OWNER_PASSWORD=USE_STRONG_PASSWORD

# --- AI (OPTIONAL) ---
GEMINI_API_KEY=
