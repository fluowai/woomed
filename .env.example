# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Porta HTTP interna da aplicacao.
PORT="5173"

# JWT_SECRET: obrigatorio em producao. Use um valor longo e aleatorio.
JWT_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# Login por PIN e legado. Mantenha false em producao; use true apenas em teste interno.
ENABLE_LEGACY_PIN_LOGIN="false"

# URL do bridge HTTP que encapsula a biblioteca Go Whatsmeow.
# Exemplo em Docker/Portainer quando o bridge esta no mesmo stack:
# WHATSMEOW_API_URL="http://whatsmeow-bridge:8080"
WHATSMEOW_API_URL=""

# Token opcional enviado como Bearer para o bridge Whatsmeow.
WHATSMEOW_API_TOKEN=""

# Segredo opcional exigido no header x-whatsmeow-secret dos webhooks.
WHATSMEOW_WEBHOOK_SECRET=""

# Supabase: usado na fase SaaS.
# No frontend use apenas URL + anon key. A service role key fica somente no backend.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_URL=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Email inicial do dono da plataforma. Troque antes de aplicar o seed em producao.
PLATFORM_OWNER_EMAIL="owner@consultio.local"
