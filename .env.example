# ==============================================================
# Consultio Med - Template de Ambiente
# Copie para .env e preencha os valores
# ==============================================================

# --- APLICACAO ---
NODE_ENV=production
PORT=5173
APP_URL=http://localhost:5173
CORS_ORIGIN=true

# --- SEGURANCA (GERAR VALORES UNICOS!) ---
# Gere com: openssl rand -base64 32
JWT_SECRET=mude-para-um-valor-aleatorio
# Gere com: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=mude-para-um-valor-hex-64-caracteres

# --- BANCO DE DADOS (ESCOLHA UMA OPCAO) ---
# Opcao 1: PostgreSQL interno (Docker)
DB_PASSWORD=senha_segura_do_banco
# Opcao 2: Usar string de conexao direta (descomente)
# DATABASE_URL=postgresql://usuario:senha@host:5432/consultio

# Opcao 3: Supabase (descomente abaixo)
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_ANON_KEY=sua-chave-anon
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# VITE_SUPABASE_ANON_KEY=sua-chave-anon

# --- WHATSAPP ---
WHATSMEOW_API_URL=
WHATSMEOW_API_TOKEN=
WHATSMEOW_WEBHOOK_SECRET=mude-para-um-segredo-aleatorio

# --- GEMINI AI (OPCIONAL) ---
# Obtenha em: https://aistudio.google.com/
GEMINI_API_KEY=

# --- PLATAFORMA ---
PLATFORM_OWNER_EMAIL=owner@consultio.local

# --- DEV (APENAS AMBIENTE LOCAL) ---
# ENABLE_LEGACY_PIN_LOGIN=true
