# ============================================================
# Consultio Med - Variaveis de Ambiente para Portainer
# ============================================================
# Copie este conteudo para o campo "Environment variables"
# do Portainer ao criar a stack.
# ============================================================

# --- APLICACAO ---
APP_URL=http://localhost:5173
CORS_ORIGIN=true

# --- SEGURANCA (GERAR VALORES UNICOS!) ---
# Gere com: openssl rand -base64 32
JWT_SECRET=coloque-um-valor-aleatorio-aqui-mude-urgente
# Gere com: openssl rand -hex 32
ENCRYPTION_MASTER_KEY=coloque-um-valor-hex-aqui-mude-urgente

# --- DOMINIO E HTTPS (Caddy) ---
# Apos configurar DNS, preencha com https://
APP_DOMAIN=http://localhost:5173
ACME_EMAIL=admin@seudominio.com.br

# --- BANCO DE DADOS (ESCOLHA UMA OPCAO) ---

# Opcao 1: PostgreSQL interno (recomendado)
# O servico postgres usa DB_PASSWORD. O DATABASE_URL e montado automaticamente.
DB_PASSWORD=consultio_db_password_segura

# Opcao 2: Supabase (descomente e comente a opcao 1)
# DATABASE_URL=postgresql://postgres:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://seu-projeto.supabase.co
# SUPABASE_ANON_KEY=sua-anon-key
# VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# VITE_SUPABASE_ANON_KEY=sua-anon-key

# --- WHATSAPP ---
WHATSMEOW_WEBHOOK_SECRET=coloque-um-segredo-aleatorio-aqui
WHATSMEOW_API_TOKEN=

# --- GEMINI AI (OPCIONAL) ---
GEMINI_API_KEY=

# --- PLATAFORMA ---
PLATFORM_OWNER_EMAIL=owner@consultio.local

# --- SCRIPTS (OPCIONAL) ---
# Caminho para script de init do banco (relativo ao contexto do build)
# SCRIPT_INIT_DB=./scripts/init-db.sh
